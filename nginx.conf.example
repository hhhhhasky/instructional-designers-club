# Nginx 配置示例
# 文件位置：/etc/nginx/sites-available/www.hasky.top
# 
# 使用方法：
# 1. 将此配置复制到 /etc/nginx/sites-available/www.hasky.top
# 2. 创建符号链接：sudo ln -s /etc/nginx/sites-available/www.hasky.top /etc/nginx/sites-enabled/
# 3. 测试配置：sudo nginx -t
# 4. 重启 Nginx：sudo systemctl restart nginx

server {
    listen 80;
    listen [::]:80;
    server_name www.hasky.top hasky.top;

    # 网站根目录
    root /var/www/html/dist;
    index index.html;

    # 日志文件
    access_log /var/log/nginx/hasky.top.access.log;
    error_log /var/log/nginx/hasky.top.error.log;

    # Gzip 压缩
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/xml text/javascript application/x-javascript application/xml+rss application/json application/javascript;

    # 验证文件 - 直接返回，不重定向
    location ~* ^/[a-f0-9]{32}\.txt$ {
        add_header Content-Type "text/plain; charset=utf-8";
        add_header Cache-Control "public, max-age=3600";
        try_files $uri =404;
    }

    # 静态资源缓存
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # SPA 路由 - 所有其他请求
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 安全头部
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
}

# HTTPS 配置（如果使用 SSL）
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.hasky.top hasky.top;

    # SSL 证书
    ssl_certificate /etc/letsencrypt/live/www.hasky.top/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/www.hasky.top/privkey.pem;

    # SSL 配置
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # 网站根目录
    root /var/www/html/dist;
    index index.html;

    # 日志文件
    access_log /var/log/nginx/hasky.top.access.log;
    error_log /var/log/nginx/hasky.top.error.log;

    # Gzip 压缩
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/xml text/javascript application/x-javascript application/xml+rss application/json application/javascript;

    # 验证文件 - 直接返回，不重定向
    location ~* ^/[a-f0-9]{32}\.txt$ {
        add_header Content-Type "text/plain; charset=utf-8";
        add_header Cache-Control "public, max-age=3600";
        try_files $uri =404;
    }

    # 静态资源缓存
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # SPA 路由 - 所有其他请求
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 安全头部
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
}

# HTTP 重定向到 HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name www.hasky.top hasky.top;
    return 301 https://$server_name$request_uri;
}
